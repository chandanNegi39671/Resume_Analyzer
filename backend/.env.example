# Ollama HTTP endpoint for local LLM inference service
OLLAMA_BASE_URL=http://localhost:11434

# Ollama model used for resume analysis generation
OLLAMA_MODEL=gemma:2b

# Ollama request timeout in seconds
OLLAMA_TIMEOUT=60

# Allowed frontend origin for CORS
FRONTEND_ORIGIN=http://localhost:5173

# Maximum upload size in megabytes for resume files
MAX_FILE_SIZE_MB=5
